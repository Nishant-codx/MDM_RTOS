#include <Arduino_LSM9DS1.h>

String lastCommand = "";

unsigned long lastAction = 0;   // ADD THIS HERE


void setup() {
  Serial.begin(9600);
  while (!Serial);

  if (!IMU.begin()) {
    Serial.println("IMU initialization failed!");
    while (1);
  }

  Serial.println("Controller Ready");
}


void loop() {

  float ax, ay, az;

  if (IMU.accelerationAvailable()) {

    IMU.readAcceleration(ax, ay, az);

    String command = "";


    // LEFT
    if (ax < -0.5) {
      command = "LEFT";
    }

    // RIGHT
    else if (ax > 0.4) {
      command = "RIGHT";
    }

    // JUMP
    else if (ay > 0.5) {
      command = "JUMP";
    }

    // ROLL
    else if (ay < -0.5) {
      command = "ROLL";
    }


    // SEND COMMAND WITH COOLDOWN
    if (command != "" && millis() - lastAction > 300) {

      Serial.println(command);

      lastAction = millis();

    }


    // Reset when neutral
    if (abs(ax) < 0.2 && abs(ay) < 0.2) {
      lastCommand = "";
    }

  }


  delay(40);
}


